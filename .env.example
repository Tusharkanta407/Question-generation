# App URL (watch links in emails)
APP_URL="http://localhost:3000"

# NextAuth (required — no empty NEXTAUTH_SECRET or you get [NO_SECRET] / unstable sessions)
# Generate:  openssl rand -base64 32
NEXTAUTH_SECRET=""
# Must match the URL you open in the browser (dev: http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Web Client (Credentials → OAuth 2.0 Client ID → Web application)
# Authorised redirect URIs MUST include exactly (NextAuth — do not use /api/google/callback):
#   http://localhost:3000/api/auth/callback/google
# You can use either pair of variable names:
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# (aliases) GOOGLE_OAUTH_CLIENT_ID=""  GOOGLE_OAUTH_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI is not read by this app; NextAuth fixes the path to /api/auth/callback/google

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Target folder for uploads — must be a folder in the SAME Google account that signs in (create in Drive, copy id from URL)
GOOGLE_DRIVE_FOLDER_ID=""

# Optional: service account (only if you still use /api/health/infra Drive check without OAuth)
GOOGLE_SERVICE_ACCOUNT_FILE=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# Email provider (preferred for dev demo): SMTP / Nodemailer
# Example (Gmail app password):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# SMTP_FROM="Teacher Platform <you@gmail.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Resend (fallback when SMTP_* is not configured)
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"
RESEND_TEST_TO=""

# Lecture watch tokens
LECTURE_TOKEN_SECRET=""
LECTURE_TOKEN_TTL_HOURS="72"

# Hybrid RAG (run supabase/schema_rag.sql first)
# OpenRouter: embeddings + generation (one key for everything)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Live web search (optional — Brave OR Google Programmable Search)
BRAVE_API_KEY=""
# GOOGLE_CSE_API_KEY=""
# GOOGLE_CSE_ID=""

# RAG tuning (optional)
# RAG_CORPUS_TOP_K="8"
# RAG_WEB_RESULTS="6"
# RAG_WEB_FETCH_TOP_N="0"
# RAG_WEB_FETCH_MAX_CHARS="2800"
# RAG_MAX_CONTEXT_CHARS="24000"
# RAG_RATE_LIMIT_PER_MIN="30"
# RAG_GENERATION_MODEL="gemini-2.0-flash"
# RAG_QUERY_REWRITE_MODEL="gemini-2.0-flash"
# RAG_SKIP_QUERY_REWRITE="0"
